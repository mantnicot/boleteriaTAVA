# OAuth 2.0 — cuenta Gmail personal (Google Cloud → Credenciales → ID de cliente OAuth "Aplicación web")
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Debe coincidir EXACTAMENTE con la URI autorizada en Google Cloud (mismo puerto que PORT)
GOOGLE_REDIRECT_URI=http://localhost:3000/oauth2callback

# Base pública (sin / final) para enlaces en el QR de la boleta — ej. https://tu-dominio.com o http://localhost:3000
PUBLIC_BASE_URL=http://localhost:3000

# Opcional: firma dedicada del QR de verificación (por defecto se usa APP_SESSION_SECRET o GOOGLE_CLIENT_SECRET)
VERIFICACION_QR_SECRET=

# Opcional (recomendado en Vercel): pega aquí el JSON completo de tokens OAuth para evitar guardar en disco.
# Ejemplo: {"access_token":"...","refresh_token":"...","scope":"...","token_type":"Bearer","expiry_date":123}
GOOGLE_OAUTH_TOKENS_JSON=

# Login interno por correo (si no configuras APP_LOGIN_ALLOWED_EMAILS, se permite cualquier correo válido).
# En producción configura APP_SESSION_SECRET y una lista de correos autorizados separada por comas.
APP_SESSION_SECRET=
APP_LOGIN_ALLOWED_EMAILS=

# Opcional: carpeta de Drive para imágenes de boleta (ID en .../folders/ID)
GOOGLE_DRIVE_FOLDER_ID=

# Opcional: ID de hoja existente
GOOGLE_SHEETS_ID=

# Opcional: si SMTP_USER y SMTP_PASS están vacíos, no se envía correo
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM=

PORT=3000
OPEN_BROWSER=true
