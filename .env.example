# OAuth 2.0 — cuenta Gmail personal (Google Cloud → Credenciales → ID de cliente OAuth "Aplicación web")
GOOGLE_CLIENT_ID=GOOGLE_CLIENT_SECRET=

# Debe coincidir EXACTAMENTE con la URI autorizada en Google Cloud (mismo puerto que PORT)
GOOGLE_REDIRECT_URI=http://localhost:3000/oauth2callback

# Opcional (recomendado en Vercel): pega aquí el JSON completo de tokens OAuth para evitar guardar en disco.
# Ejemplo: {"access_token":"...","refresh_token":"...","scope":"...","token_type":"Bearer","expiry_date":123}
GOOGLE_OAUTH_TOKENS_JSON=

# Opcional: carpeta de Drive para imágenes de boleta (ID en .../folders/ID). Si está vacío se usa la carpeta por defecto del proyecto.
GOOGLE_DRIVE_FOLDER_ID=

# Opcional: ID de hoja existente. Si está vacío, el sistema crea una hoja nueva en tu Drive la primera vez.
GOOGLE_SHEETS_ID=

# Opcional: si SMTP_USER y SMTP_PASS están vacíos, no se envía correo (la boleta PDF igual se descarga).
# Gmail: contraseña de aplicación (no la contraseña normal de la cuenta).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM=

PORT=3000

# Al iniciar el servidor, abrir el navegador en http://localhost:PORT/#inicio (poner 0 o false para desactivar)
OPEN_BROWSER=true
